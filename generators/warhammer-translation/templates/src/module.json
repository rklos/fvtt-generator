{
  "id": "<%= id %>",
  "title": "<%= title %>",
  "description": "<%= description %>",
  "authors": [
    {
      "name": "<%= author %>",
      "email": "<%= email %>"
    }
  ],
  "version": "0.1.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13",
    "maximum": "13"
  },
  "relationships": {
    "systems": [
      {
        "id": "<%= requiredSystemId %>",
        "type": "system",
        "compatibility": {
          "minimum": "<%= requiredSystemMinVersion %>",
          "verified": "<%= requiredSystemMinVersion %>"
        }
      }
    ],
    "requires": [
      {
        "id": "babele",
        "type": "module"
      }
    ]
  },
  "coreTranslation": true,
  "scripts": [
    "<%= outputFilename %>.js"
  ],
  "styles": [
    "<%= outputFilename %>.css"
  ],
  "languages": [
    {
      "lang": "pl",
      "name": "Polski",
      "path": "lang/pl.json",
      "flags": {}
    }
  ],
  "license": "LICENSE",
  "readme": "README.md",
  "url": "https://github.com/rklos/<%= id %>",
  "manifest": "https://github.com/rklos/<%= id %>/releases/latest/download/module.json",
  "download": "https://github.com/rklos/<%= id %>/releases/latest/download/<%= id %>.zip"
}
